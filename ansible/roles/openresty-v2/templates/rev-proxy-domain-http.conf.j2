{% set domain = item %}
{% set stripped_domain = domain.split('.')[0] %}
server {
    listen 80 proxy_protocol;
    server_name $host;

    location ~ /.well-known {
        root /var/www/certbot;
        allow all;
        proxy_set_header X-Forwarded-For $proxy_protocol_addr;
   }
   real_ip_header proxy_protocol; 
}